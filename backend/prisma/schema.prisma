// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model animal {
  id Int @unique @default(autoincrement())
  name String
  legs Int
  fact String
  likes Int
}